source "https://rubygems.org"

# Use a modern version of Jekyll that compiles perfectly everywhere
gem "jekyll", "~> 4.3"

# Explicitly declare the Minimal theme package
gem "jekyll-theme-minimal", "~> 0.2.0"

# Explicitly add the GitHub Pages plugins you actually need
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
